@{
    ViewData["Title"] = "Добавить журнал";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card mt-4">
            <div class="card-header text-center"><h4>Добавить журнал</h4></div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form method="post" asp-action="CreateJournal">
                    <div class="mb-3">
                        <label class="form-label">Название</label>
                        <input type="text" name="title" class="form-control" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">ISSN</label>
                            <input type="text" name="issn" class="form-control" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">E-ISSN</label>
                            <input type="text" name="eIssn" class="form-control" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Издатель</label>
                        <input type="text" name="publisher" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Тематика</label>
                        <input type="text" name="subjectArea" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Квартиль</label>
                        <select name="quartile" class="form-select">
                            <option value="0">Не указан</option>
                            <option value="1">Q1</option>
                            <option value="2">Q2</option>
                            <option value="3">Q3</option>
                            <option value="4">Q4</option>
                        </select>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="isVak" value="true" />
                        <label class="form-check-label">Входит в ВАК</label>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" name="isWhiteList" value="true" />
                        <label class="form-check-label">Входит в Белый список</label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Страна</label>
                        <input type="text" name="country" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ссылка</label>
                        <input type="text" name="url" class="form-control" />
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-success">Сохранить</button>
                        <a asp-action="Journals" class="btn btn-outline-secondary">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>