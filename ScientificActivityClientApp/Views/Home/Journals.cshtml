@model List<JournalViewModel>
@using ScientificActivityDataModels.Enums

@{
    ViewData["Title"] = "Журналы";
}

<h2 class="mb-4">Журналы</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (APIClient.Researcher?.Role == UserRole.Администратор)
{
    <div class="mb-3">
        <a asp-action="CreateJournal" class="btn btn-primary">Добавить журнал</a>
    </div>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Название</th>
            <th>ISSN</th>
            <th>Тематика</th>
            <th>ВАК</th>
            <th>Белый список</th>
            @if (APIClient.Researcher?.Role == UserRole.Администратор)
            {
                <th>Действия</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Issn</td>
                <td>@item.SubjectArea</td>
                <td>@(item.IsVak ? "Да" : "Нет")</td>
                <td>@(item.IsWhiteList ? "Да" : "Нет")</td>
                @if (APIClient.Researcher?.Role == UserRole.Администратор)
                {
                    <td>
                        <div class="d-flex gap-2">
                            <a asp-action="UpdateJournal" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Изменить</a>
                            <form method="post" asp-action="DeleteJournal">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">Удалить</button>
                            </form>
                        </div>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>