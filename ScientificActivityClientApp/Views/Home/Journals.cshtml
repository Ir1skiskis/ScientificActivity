@model List<ScientificActivityContracts.ViewModels.JournalViewModel>
@using ScientificActivityDataModels.Enums

@{
    ViewData["Title"] = "Журналы";
}

<h2>Журналы</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (APIClient.Researcher?.Role == UserRole.Администратор)
{
    <div class="mb-3 d-flex gap-2 flex-wrap">
        <a asp-action="CreateJournal" class="btn btn-primary">Добавить журнал</a>
        <a asp-action="ImportAllJournals" class="btn btn-outline-primary">Полный импорт журналов</a>

        <a asp-action="ImportVakJournals" class="btn btn-outline-secondary">Импорт ВАК</a>

        <form asp-action="ImportWhiteListJournals" method="post" class="d-inline">
            <button type="submit" class="btn btn-outline-secondary">
                Импорт Белого списка
            </button>
        </form>

        <form asp-action="EnrichWhiteListRcsiLinks" method="post" class="d-inline">
            <button type="submit" class="btn btn-outline-warning">
                Заполнить Rcsi ID и URL
            </button>
        </form>

        <form asp-action="EnrichWhiteListSubjectAreas" method="post" class="d-inline">
            <button type="submit" class="btn btn-outline-success">
                Заполнить тематики РЦНИ
            </button>
        </form>
    </div>
}

<form method="get" asp-action="Journals" class="mb-4">
    <div class="row g-2">
        <div class="col-md-3">
            <input type="text"
                   name="title"
                   value="@ViewBag.TitleFilter"
                   class="form-control"
                   placeholder="Поиск по названию" />
        </div>

        <div class="col-md-3">
            <input type="text"
                   name="issn"
                   value="@ViewBag.IssnFilter"
                   class="form-control"
                   placeholder="Поиск по ISSN" />
        </div>

        <div class="col-md-2">
            <select name="isVak" class="form-select">
                <option value="">Все журналы</option>

                @if (ViewBag.IsVakFilter != null && (bool)ViewBag.IsVakFilter == true)
                {
                    <option value="true" selected>Только ВАК</option>
                }
                else
                {
                    <option value="true">Только ВАК</option>
                }

                @if (ViewBag.IsVakFilter != null && (bool)ViewBag.IsVakFilter == false)
                {
                    <option value="false" selected>Не ВАК</option>
                }
                else
                {
                    <option value="false">Не ВАК</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <select name="isWhiteList" class="form-select">
                <option value="">Любой статус БС</option>

                @if (ViewBag.IsWhiteListFilter != null && (bool)ViewBag.IsWhiteListFilter == true)
                {
                    <option value="true" selected>Только Белый список</option>
                }
                else
                {
                    <option value="true">Только Белый список</option>
                }

                @if (ViewBag.IsWhiteListFilter != null && (bool)ViewBag.IsWhiteListFilter == false)
                {
                    <option value="false" selected>Без Белого списка</option>
                }
                else
                {
                    <option value="false">Без Белого списка</option>
                }
            </select>
        </div>

        <div class="col-md-1">
            <button type="submit" class="btn btn-success w-100">Найти</button>
        </div>

        <div class="col-md-1">
            <a asp-action="Journals" class="btn btn-outline-secondary w-100">Сброс</a>
        </div>
    </div>
</form>

<p>
    Найдено журналов: <strong>@ViewBag.TotalCount</strong>
</p>

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Название</th>
            <th>ISSN</th>
            <th>Тематика</th>
            <th>ВАК</th>
            <th>Белый список</th>
            <th>Уровень БС 2025</th>
            @if (APIClient.Researcher?.Role == UserRole.Администратор)
            {
                <th>Действия</th>
            }
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@(string.IsNullOrWhiteSpace(item.Issn) ? "—" : item.Issn)</td>
                <td>@(string.IsNullOrWhiteSpace(item.SubjectArea) ? "—" : item.SubjectArea)</td>
                <td>@(item.IsVak ? "Да" : "Нет")</td>
                <td>@(item.IsWhiteList ? "Да" : "Нет")</td>
                <td>
                    @if (!item.IsWhiteList)
                    {
                        <span>Не в БС</span>
                    }
                    else if (!item.WhiteListLevel2025.HasValue)
                    {
                        <span>Без уровня</span>
                    }
                    else
                    {
                        <span>@item.WhiteListLevel2025</span>
                    }
                </td>

                @if (APIClient.Researcher?.Role == UserRole.Администратор)
                {
                    <td>
                        <div class="d-flex gap-2">
                            <a asp-action="UpdateJournal"
                               asp-route-id="@item.Id"
                               class="btn btn-sm btn-warning">
                                Изменить
                            </a>

                            <form asp-action="DeleteJournal" method="post" onsubmit="return confirm('Удалить журнал?');">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-sm btn-danger">Удалить</button>
                            </form>
                        </div>
                    </td>
                }
            </tr>
        }
    </tbody>
</table>

@if ((int)ViewBag.TotalPages > 1)
{
    var currentPage = (int)ViewBag.CurrentPage;
    var totalPages = (int)ViewBag.TotalPages;

    var startPage = Math.Max(1, currentPage - 2);
    var endPage = Math.Min(totalPages, currentPage + 2);

    <nav class="d-flex justify-content-center mt-4">
        <ul class="pagination shadow-sm">
            @if (currentPage > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-action="Journals"
                       asp-route-page="1"
                       asp-route-title="@ViewBag.TitleFilter"
                       asp-route-issn="@ViewBag.IssnFilter"
                       asp-route-isVak="@ViewBag.IsVakFilter"
                       asp-route-isWhiteList="@ViewBag.IsWhiteListFilter">
                        «
                    </a>
                </li>

                <li class="page-item">
                    <a class="page-link"
                       asp-action="Journals"
                       asp-route-page="@(currentPage - 1)"
                       asp-route-title="@ViewBag.TitleFilter"
                       asp-route-issn="@ViewBag.IssnFilter"
                       asp-route-isVak="@ViewBag.IsVakFilter"
                       asp-route-isWhiteList="@ViewBag.IsWhiteListFilter">
                        ‹
                    </a>
                </li>
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                if (i == currentPage)
                {
                    <li class="page-item active">
                        <span class="page-link">@i</span>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        <a class="page-link"
                           asp-action="Journals"
                           asp-route-page="@i"
                           asp-route-title="@ViewBag.TitleFilter"
                           asp-route-issn="@ViewBag.IssnFilter"
                           asp-route-isVak="@ViewBag.IsVakFilter"
                           asp-route-isWhiteList="@ViewBag.IsWhiteListFilter">
                            @i
                        </a>
                    </li>
                }
            }

            @if (currentPage < totalPages)
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-action="Journals"
                       asp-route-page="@(currentPage + 1)"
                       asp-route-title="@ViewBag.TitleFilter"
                       asp-route-issn="@ViewBag.IssnFilter"
                       asp-route-isVak="@ViewBag.IsVakFilter"
                       asp-route-isWhiteList="@ViewBag.IsWhiteListFilter">
                        ›
                    </a>
                </li>

                <li class="page-item">
                    <a class="page-link"
                       asp-action="Journals"
                       asp-route-page="@totalPages"
                       asp-route-title="@ViewBag.TitleFilter"
                       asp-route-issn="@ViewBag.IssnFilter"
                       asp-route-isVak="@ViewBag.IsVakFilter"
                       asp-route-isWhiteList="@ViewBag.IsWhiteListFilter">
                        »
                    </a>
                </li>
            }
        </ul>
    </nav>
}