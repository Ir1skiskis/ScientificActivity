@model ResearcherViewModel
@using ScientificActivityDataModels.Enums
@using ScientificActivityContracts.ViewModels

@{
    ViewData["Title"] = "Профиль";
}
@{
    var allTags = ViewBag.AllTags as List<TagViewModel> ?? new List<TagViewModel>();
    var selectedTags = ViewBag.SelectedTags as List<TagViewModel> ?? new List<TagViewModel>();
    var selectedTagIds = selectedTags.Select(x => x.Id).ToHashSet();
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card mt-4">
            <div class="card-header text-center">
                <h4>Профиль исследователя</h4>
            </div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        @ViewBag.Error
                    </div>
                }

                @if (ViewBag.Message != null)
                {
                    <div class="alert alert-success">
                        @ViewBag.Message
                    </div>
                }

                @if (TempData["Message"] != null)
                {
                    <div class="alert alert-success">
                        @TempData["Message"]
                    </div>
                }

                <form method="post" asp-action="Profile">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Фамилия</label>
                            <input type="text" name="lastName" class="form-control" value="@Model.LastName" required />
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Имя</label>
                            <input type="text" name="firstName" class="form-control" value="@Model.FirstName" required />
                        </div>

                        <div class="col-md-4 mb-3">
                            <label class="form-label">Отчество</label>
                            <input type="text" name="middleName" class="form-control" value="@Model.MiddleName" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" name="email" class="form-control" value="@Model.Email" required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Телефон</label>
                            <input type="text" name="phone" class="form-control" value="@Model.Phone" required />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Кафедра / подразделение</label>
                            <input type="text" name="department" class="form-control" value="@Model.Department" required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Должность</label>
                            <input type="text" name="position" class="form-control" value="@Model.Position" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Учёная степень</label>
                        <select name="academicDegree" class="form-select">
                            <option value="0" selected="@(Model.AcademicDegree == AcademicDegree.Не_указано)">Не указано</option>
                            <option value="1" selected="@(Model.AcademicDegree == AcademicDegree.Без_степени)">Без степени</option>
                            <option value="2" selected="@(Model.AcademicDegree == AcademicDegree.Кандидат_наук)">Кандидат наук</option>
                            <option value="3" selected="@(Model.AcademicDegree == AcademicDegree.Доктор_наук)">Доктор наук</option>
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">ID автора eLibrary</label>
                        <input type="text" name="eLibraryAuthorId" class="form-control" value="@Model.ELibraryAuthorId" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Научные интересы (текстовое описание)</label>
                        <textarea name="researchTopics" class="form-control" rows="3" placeholder="Например: искусственный интеллект, анализ данных, медицинские информационные системы">@Model.ResearchTopics</textarea>
                        <div class="form-text">
                            Это свободное текстовое описание. Для подбора рекомендаций используйте блок тегов ниже.
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Новый пароль</label>
                        <input type="password" name="newPassword" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Количество публикаций</label>
                        <input type="text" class="form-control" value="@Model.PublicationsCount" readonly />
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Сохранить изменения</button>
                    </div>
                </form>

                <hr class="my-4" />

                <h5 class="mb-3">Интересы для рекомендаций</h5>

                <form method="post" asp-controller="Recommendation" asp-action="SaveResearcherTags" id="researcherTagsForm">
                    <div class="card border-light mb-3">
                        <div class="card-body">
                            <div class="mb-3">
                                <label class="form-label">Поиск тегов</label>
                                <input type="text"
                                       id="tagSearchInput"
                                       class="form-control"
                                       placeholder="Введите код или название тега, например: 3.1.18, Кардиология, искусственный интеллект" />

                                <div class="form-text">
                                    Начните вводить код или название направления. Уже выбранные теги сохраняются даже после очистки поиска.
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Найденные теги</label>

                                <div id="tagSearchResults" class="border rounded p-2" style="max-height: 260px; overflow-y: auto;">
                                    <div class="text-muted">
                                        Введите текст для поиска тегов.
                                    </div>
                                </div>

                                <div class="form-text">
                                    Можно выбрать несколько тегов.
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Выбранные теги</label>

                                <div id="selectedTagsContainer" class="border rounded p-2 min-vh-25">
                                    @if (selectedTags.Any())
                                    {
                                        @foreach (var tag in selectedTags.OrderBy(x => x.Name))
                                        {
                                            <span class="badge bg-secondary me-1 mb-1 selected-tag-badge"
                                                  data-tag-id="@tag.Id">
                                                @tag.Name
                                                <button type="button"
                                                        class="btn-close btn-close-white ms-1 remove-selected-tag-btn"
                                                        aria-label="Удалить тег"
                                                        data-tag-id="@tag.Id">
                                                </button>
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted" id="noSelectedTagsText">Теги пока не выбраны.</span>
                                    }
                                </div>
                            </div>

                            <div id="hiddenSelectedTags">
                                @foreach (var tag in selectedTags)
                                {
                                    <input type="hidden" name="tagIds" value="@tag.Id" data-tag-id="@tag.Id" />
                                }
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-outline-primary">
                                    Сохранить интересы для рекомендаций
                                </button>

                                <a asp-controller="Recommendation" asp-action="Index" class="btn btn-success">
                                    Перейти к рекомендациям
                                </a>
                            </div>
                        </div>
                    </div>
                </form>

                <script>
                    const allTags = [
                        @foreach (var tag in allTags.OrderBy(x => x.Name))
                        {
                                <text>{ id: @tag.Id, name: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(tag.Name)) },</text>
                        }
                    ];

                    const selectedTagIds = new Set([
                        @foreach (var tagId in selectedTagIds)
                        {
                                <text>@tagId,</text>
                        }
                    ]);

                    const tagSearchInput = document.getElementById('tagSearchInput');
                    const tagSearchResults = document.getElementById('tagSearchResults');
                    const selectedTagsContainer = document.getElementById('selectedTagsContainer');
                    const hiddenSelectedTags = document.getElementById('hiddenSelectedTags');

                    function normalizeText(value) {
                        return value
                            .toString()
                            .toLowerCase()
                            .replaceAll('ё', 'е')
                            .trim();
                    }

                    function renderSearchResults() {
                        const query = normalizeText(tagSearchInput.value);

                        tagSearchResults.innerHTML = '';

                        if (query.length < 2) {
                            tagSearchResults.innerHTML = '<div class="text-muted">Введите минимум 2 символа для поиска.</div>';
                            return;
                        }

                        const foundTags = allTags
                            .filter(tag => normalizeText(tag.name).includes(query))
                            .slice(0, 80);

                        if (foundTags.length === 0) {
                            tagSearchResults.innerHTML = '<div class="text-muted">По вашему запросу теги не найдены.</div>';
                            return;
                        }

                        foundTags.forEach(tag => {
                            const wrapper = document.createElement('div');
                            wrapper.className = 'form-check mb-1';

                            const checkbox = document.createElement('input');
                            checkbox.className = 'form-check-input';
                            checkbox.type = 'checkbox';
                            checkbox.id = `tag-checkbox-${tag.id}`;
                            checkbox.value = tag.id;
                            checkbox.checked = selectedTagIds.has(tag.id);

                            checkbox.addEventListener('change', function () {
                                if (this.checked) {
                                    addSelectedTag(tag.id, tag.name);
                                } else {
                                    removeSelectedTag(tag.id);
                                }
                            });

                            const label = document.createElement('label');
                            label.className = 'form-check-label';
                            label.htmlFor = `tag-checkbox-${tag.id}`;
                            label.textContent = tag.name;

                            wrapper.appendChild(checkbox);
                            wrapper.appendChild(label);

                            tagSearchResults.appendChild(wrapper);
                        });
                    }

                                        function addSelectedTag(tagId, tagName) {
                        selectedTagIds.add(tagId);

                        const noSelectedTagsText = document.getElementById('noSelectedTagsText');
                        if (noSelectedTagsText) {
                            noSelectedTagsText.remove();
                        }

                        const existingBadge = selectedTagsContainer.querySelector(`.selected-tag-badge[data-tag-id="${tagId}"]`);
                        if (!existingBadge) {
                            const badge = document.createElement('span');
                            badge.className = 'badge bg-secondary me-1 mb-1 selected-tag-badge';
                            badge.dataset.tagId = tagId;

                            const text = document.createTextNode(tagName + ' ');
                            badge.appendChild(text);

                            const removeButton = document.createElement('button');
                            removeButton.type = 'button';
                            removeButton.className = 'btn-close btn-close-white ms-1 remove-selected-tag-btn';
                            removeButton.setAttribute('aria-label', 'Удалить тег');
                            removeButton.dataset.tagId = tagId;

                            removeButton.addEventListener('click', function () {
                                removeSelectedTag(tagId);
                            });

                            badge.appendChild(removeButton);
                            selectedTagsContainer.appendChild(badge);
                        }

                        const existingInput = hiddenSelectedTags.querySelector(`input[data-tag-id="${tagId}"]`);
                        if (!existingInput) {
                            const input = document.createElement('input');
                            input.type = 'hidden';
                            input.name = 'tagIds';
                            input.value = tagId;
                            input.dataset.tagId = tagId;

                            hiddenSelectedTags.appendChild(input);
                        }

                        updateVisibleCheckboxes();
                    }

                    function removeSelectedTag(tagId) {
                        selectedTagIds.delete(tagId);

                        const badge = selectedTagsContainer.querySelector(`[data-tag-id="${tagId}"]`);
                        if (badge) {
                            badge.remove();
                        }

                        const input = hiddenSelectedTags.querySelector(`input[data-tag-id="${tagId}"]`);
                        if (input) {
                            input.remove();
                        }

                        if (selectedTagIds.size === 0) {
                            selectedTagsContainer.innerHTML = '<span class="text-muted" id="noSelectedTagsText">Теги пока не выбраны.</span>';
                        }

                        updateVisibleCheckboxes();
                    }

                    function updateVisibleCheckboxes() {
                        const checkboxes = tagSearchResults.querySelectorAll('input[type="checkbox"]');

                        checkboxes.forEach(checkbox => {
                            const tagId = Number(checkbox.value);
                            checkbox.checked = selectedTagIds.has(tagId);
                        });
                    }

                    function initializeSelectedTagRemoveButtons() {
                        const removeButtons = selectedTagsContainer.querySelectorAll('.remove-selected-tag-btn');

                        removeButtons.forEach(button => {
                            button.addEventListener('click', function () {
                                const tagId = Number(this.dataset.tagId);
                                removeSelectedTag(tagId);
                            });
                        });
                    }

                    tagSearchInput.addEventListener('input', renderSearchResults);
                    initializeSelectedTagRemoveButtons();
                </script>

                <style>
                    .selected-tag-badge {
                        display: inline-flex;
                        align-items: center;
                        white-space: normal;
                        text-align: left;
                        max-width: 100%;
                    }

                        .selected-tag-badge .btn-close {
                            width: 0.55rem;
                            height: 0.55rem;
                            padding: 0.15rem;
                            flex-shrink: 0;
                        }
                </style>

                @{
                    var eLibraryProfile = ViewBag.ELibraryProfile as ELibraryAuthorProfileViewModel;
                }

                <hr class="my-4" />

                <div class="card border-primary mb-4">
                    <div class="card-header bg-primary text-white">
                        <div class="d-flex justify-content-between align-items-center">
                            <span>Профиль eLibrary</span>
                            @if (!string.IsNullOrWhiteSpace(Model.ELibraryAuthorId))
                            {
                                <span class="badge bg-light text-primary">
                                    AuthorId: @Model.ELibraryAuthorId
                                </span>
                            }
                        </div>
                    </div>

                    <div class="card-body">
                        <p class="text-muted mb-4">
                            В этом разделе можно привязать профиль автора eLibrary, загрузить наукометрические показатели
                            и импортировать список публикаций исследователя.
                        </p>

                        <div class="alert alert-light border d-flex align-items-start gap-3 mb-4">
                            <div class="fs-4 text-warning">
                                🔐
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-semibold mb-1">
                                    Ручная авторизация в eLibrary
                                </div>
                                <div class="text-muted small mb-3">
                                    Используется только при первом входе или если eLibrary ограничивает доступ к страницам автора.
                                    После авторизации данные сохраняются в Selenium-профиле браузера.
                                </div>

                                <form method="post" asp-action="OpenManualLogin">
                                    <button type="submit" class="btn btn-outline-warning">
                                        Войти в eLibrary вручную
                                    </button>
                                </form>
                            </div>
                        </div>

                        <form method="post" asp-action="LoadELibraryProfile" class="mb-3">
                            <div class="row">
                                <div class="col-md-8 mb-2">
                                    <label class="form-label">AuthorId eLibrary</label>
                                    <input type="text"
                                           name="authorId"
                                           class="form-control"
                                           value="@Model.ELibraryAuthorId"
                                           placeholder="Например: 1135134" />
                                </div>

                                <div class="col-md-4 d-flex align-items-end mb-2">
                                    <button type="submit" class="btn btn-outline-primary w-100">
                                        Загрузить профиль
                                    </button>
                                </div>
                            </div>
                        </form>

                        <form method="post" asp-action="BindELibraryAuthor" class="mb-3">
                            <div class="row">
                                <div class="col-md-8 mb-2">
                                    <label class="form-label">Привязать AuthorId к исследователю</label>
                                    <input type="text"
                                           name="authorId"
                                           class="form-control"
                                           value="@Model.ELibraryAuthorId"
                                           placeholder="Введите AuthorId автора" />
                                </div>

                                <div class="col-md-4 d-flex align-items-end mb-2">
                                    <button type="submit" class="btn btn-success w-100">
                                        Привязать
                                    </button>
                                </div>
                            </div>
                        </form>

                        <div class="row g-2 mt-2">
                            <div class="col-md-6">
                                <form method="post" asp-action="ImportELibraryProfile">
                                    <button type="submit" class="btn btn-warning w-100">
                                        Импортировать профиль
                                    </button>
                                </form>
                            </div>

                            <div class="col-md-6">
                                <form method="post" asp-action="ImportELibraryPublications">
                                    <button type="submit" class="btn btn-info w-100 text-white">
                                        Импортировать публикации
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card border-primary mb-4">
                    <div class="card-header bg-primary text-white">
                        Отчетность
                    </div>
                    <div class="card-body">
                        @if (eLibraryProfile != null)
                        {
                            <p class="text-muted mb-3">
                                Сформируйте настраиваемый отчет по расширенному профилю исследователя,
                                наукометрическим показателям и публикациям.
                            </p>

                            <div class="d-grid gap-2">
                                <a asp-controller="ResearcherReport"
                                   asp-action="Configure"
                                   asp-route-researcherId="@Model.Id"
                                   class="btn btn-primary btn-lg">
                                    Сформировать отчет о научной активности
                                </a>
                            </div>
                        }
                        else
                        {
                            <div class="alert alert-warning mb-0">
                                Для формирования отчета сначала загрузите или импортируйте профиль eLibrary.
                            </div>
                        }
                    </div>
                </div>

                @if (eLibraryProfile != null)
                {
                    <div class="card border-secondary">
                        <div class="card-header">
                            Данные автора из eLibrary
                        </div>
                        <div class="card-body">
                            <h6 class="mb-3">Основная информация</h6>

                            <div class="row mb-2">
                                <div class="col-md-4"><strong>ФИО:</strong></div>
                                <div class="col-md-8">@(!string.IsNullOrWhiteSpace(eLibraryProfile.FullName) ? eLibraryProfile.FullName : "Не указано")</div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-md-4"><strong>AuthorId:</strong></div>
                                <div class="col-md-8">@(!string.IsNullOrWhiteSpace(eLibraryProfile.AuthorId) ? eLibraryProfile.AuthorId : "Не указано")</div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-md-4"><strong>Организация:</strong></div>
                                <div class="col-md-8">@(!string.IsNullOrWhiteSpace(eLibraryProfile.Organization) ? eLibraryProfile.Organization : "Не указано")</div>
                            </div>

                            <div class="row mb-2">
                                <div class="col-md-4"><strong>Кафедра:</strong></div>
                                <div class="col-md-8">@(!string.IsNullOrWhiteSpace(eLibraryProfile.Department) ? eLibraryProfile.Department : "Не указано")</div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-4"><strong>SPIN-код:</strong></div>
                                <div class="col-md-8">@(!string.IsNullOrWhiteSpace(eLibraryProfile.SpinCode) ? eLibraryProfile.SpinCode : "Не указано")</div>
                            </div>

                            <h6 class="mb-3">Общие показатели</h6>

                            <div class="table-responsive mb-4">
                                <table class="table table-bordered table-sm align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Показатель</th>
                                            <th>Значение</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Число публикаций на eLibrary</td>
                                            <td>@(eLibraryProfile.PublicationsCountElibrary?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Число публикаций в РИНЦ</td>
                                            <td>@(eLibraryProfile.PublicationsCountRinc?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Число публикаций в ядре РИНЦ</td>
                                            <td>@(eLibraryProfile.PublicationsCoreRincCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Число цитирований на eLibrary</td>
                                            <td>@(eLibraryProfile.CitationsCountElibrary?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Число цитирований в РИНЦ</td>
                                            <td>@(eLibraryProfile.CitationsCountRinc?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Число цитирований в ядре РИНЦ</td>
                                            <td>@(eLibraryProfile.CitationsCoreRincCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Индекс Хирша по всем публикациям</td>
                                            <td>@(eLibraryProfile.HIndexElibrary?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Индекс Хирша по РИНЦ</td>
                                            <td>@(eLibraryProfile.HIndexRinc?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Индекс Хирша по ядру РИНЦ</td>
                                            <td>@(eLibraryProfile.HIndexCoreRinc?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Индекс Хирша без самоцитирований</td>
                                            <td>@(eLibraryProfile.HIndexWithoutSelfCitations?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Год первой публикации</td>
                                            <td>@(eLibraryProfile.FirstPublicationYear?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Процентиль по ядру РИНЦ</td>
                                            <td>@(eLibraryProfile.PercentileCoreRinc?.ToString() ?? "Не указано")</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <h6 class="mb-3">Дополнительные показатели</h6>

                            <div class="table-responsive mb-4">
                                <table class="table table-bordered table-sm align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Показатель</th>
                                            <th>Значение</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Публикаций, процитировавших работы автора</td>
                                            <td>@(eLibraryProfile.PublicationsCitingAuthorCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Ссылок на самую цитируемую публикацию</td>
                                            <td>@(eLibraryProfile.MostCitedPublicationCitationsCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Публикаций автора, процитированных хотя бы один раз</td>
                                            <td>@(eLibraryProfile.CitedPublicationsCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Среднее число цитирований на одну публикацию</td>
                                            <td>@(eLibraryProfile.AverageCitationsPerPublication?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Число самоцитирований</td>
                                            <td>@(eLibraryProfile.SelfCitationsCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Число цитирований соавторами</td>
                                            <td>@(eLibraryProfile.CoauthorCitationsCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Число соавторов</td>
                                            <td>@(eLibraryProfile.CoauthorsCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <h6 class="mb-3">Публикации и цитирования по типам</h6>

                            <div class="table-responsive mb-4">
                                <table class="table table-bordered table-sm align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Показатель</th>
                                            <th>Значение</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Статьи в зарубежных журналах</td>
                                            <td>@(eLibraryProfile.ForeignArticlesCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Статьи в российских журналах</td>
                                            <td>@(eLibraryProfile.RussianArticlesCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Статьи в журналах ВАК</td>
                                            <td>@(eLibraryProfile.VakArticlesCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Статьи в журналах с ненулевым импакт-фактором</td>
                                            <td>@(eLibraryProfile.ImpactFactorArticlesCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Цитирования из зарубежных журналов</td>
                                            <td>@(eLibraryProfile.ForeignJournalCitationsCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Цитирования из российских журналов</td>
                                            <td>@(eLibraryProfile.RussianJournalCitationsCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Цитирования из журналов ВАК</td>
                                            <td>@(eLibraryProfile.VakJournalCitationsCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Цитирования из журналов с ненулевым импакт-фактором</td>
                                            <td>@(eLibraryProfile.ImpactFactorJournalCitationsCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <h6 class="mb-3">Показатели за последние 5 лет</h6>

                            <div class="table-responsive mb-4">
                                <table class="table table-bordered table-sm align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Показатель</th>
                                            <th>Значение</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td>Публикации в РИНЦ за 5 лет</td>
                                            <td>@(eLibraryProfile.PublicationsRincLast5YearsCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Публикации в ядре РИНЦ за 5 лет</td>
                                            <td>@(eLibraryProfile.PublicationsCoreRincLast5YearsCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Цитирования в РИНЦ за 5 лет</td>
                                            <td>@(eLibraryProfile.CitationsRincLast5YearsCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Цитирования в ядре РИНЦ за 5 лет</td>
                                            <td>@(eLibraryProfile.CitationsCoreRincLast5YearsCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                        <tr>
                                            <td>Все ссылки на работы автора за 5 лет</td>
                                            <td>@(eLibraryProfile.CitationsAllLast5YearsCount?.ToString() ?? "Не указано")</td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>

                            <h6 class="mb-3">Рубрики</h6>

                            <div class="row mb-2">
                                <div class="col-md-4"><strong>Основная рубрика ГРНТИ:</strong></div>
                                <div class="col-md-8">@(!string.IsNullOrWhiteSpace(eLibraryProfile.MainRubricGrnti) ? eLibraryProfile.MainRubricGrnti : "Не указано")</div>
                            </div>

                            <div class="row mb-4">
                                <div class="col-md-4"><strong>Основная рубрика OECD:</strong></div>
                                <div class="col-md-8">@(!string.IsNullOrWhiteSpace(eLibraryProfile.MainRubricOecd) ? eLibraryProfile.MainRubricOecd : "Не указано")</div>
                            </div>
                            <h6 class="mb-3">Показатели за 5 лет</h6>

                            @if (eLibraryProfile.PublicationsRinc5YearsByEndYear != null && eLibraryProfile.PublicationsRinc5YearsByEndYear.Any())
                            {
                                <div class="table-responsive mb-4">
                                    <table class="table table-bordered table-sm">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Период</th>
                                                <th>Публикации в РИНЦ за 5 лет</th>
                                                <th>Публикации в ядре РИНЦ за 5 лет</th>
                                                <th>Цитирования в РИНЦ за 5 лет</th>
                                                <th>Цитирования в ядре РИНЦ за 5 лет</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var endYear in eLibraryProfile.PublicationsRinc5YearsByEndYear.Keys.OrderByDescending(x => x))
                                            {
                                                var startYear = endYear - 4;

                                                <tr>
                                                    <td>@startYear-@endYear</td>
                                                    <td>@(eLibraryProfile.PublicationsRinc5YearsByEndYear.ContainsKey(endYear) ? eLibraryProfile.PublicationsRinc5YearsByEndYear[endYear] : 0)</td>
                                                    <td>@(eLibraryProfile.PublicationsCoreRinc5YearsByEndYear.ContainsKey(endYear) ? eLibraryProfile.PublicationsCoreRinc5YearsByEndYear[endYear] : 0)</td>
                                                    <td>@(eLibraryProfile.CitationsRinc5YearsByEndYear.ContainsKey(endYear) ? eLibraryProfile.CitationsRinc5YearsByEndYear[endYear] : 0)</td>
                                                    <td>@(eLibraryProfile.CitationsCoreRinc5YearsByEndYear.ContainsKey(endYear) ? eLibraryProfile.CitationsCoreRinc5YearsByEndYear[endYear] : 0)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-light border">
                                    Пятилетние показатели не найдены.
                                </div>
                            }
                            <h6 class="mb-3">Годовые показатели</h6>

                            @if (eLibraryProfile.PublicationsRincByYear != null && eLibraryProfile.PublicationsRincByYear.Any())
                            {
                                <div class="table-responsive mb-4">
                                    <table class="table table-bordered table-sm">
                                        <thead class="table-light">
                                            <tr>
                                                <th>Год</th>
                                                <th>Публикации в РИНЦ</th>
                                                <th>Публикации в ядре РИНЦ</th>
                                                <th>Цитирования в РИНЦ</th>
                                                <th>Цитирования в ядре РИНЦ</th>
                                                <th>H-index РИНЦ</th>
                                                <th>H-index ядра</th>
                                                <th>Процентиль ядра</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var year in eLibraryProfile.PublicationsRincByYear.Keys.OrderByDescending(x => x))
                                            {
                                                <tr>
                                                    <td>@year</td>
                                                    <td>@(eLibraryProfile.PublicationsRincByYear.ContainsKey(year) ? eLibraryProfile.PublicationsRincByYear[year] : 0)</td>
                                                    <td>@(eLibraryProfile.PublicationsCoreRincByYear.ContainsKey(year) ? eLibraryProfile.PublicationsCoreRincByYear[year] : 0)</td>
                                                    <td>@(eLibraryProfile.CitationsRincByYear.ContainsKey(year) ? eLibraryProfile.CitationsRincByYear[year] : 0)</td>
                                                    <td>@(eLibraryProfile.CitationsCoreRincByYear.ContainsKey(year) ? eLibraryProfile.CitationsCoreRincByYear[year] : 0)</td>
                                                    <td>@(eLibraryProfile.HIndexRincByYear.ContainsKey(year) ? eLibraryProfile.HIndexRincByYear[year] : 0)</td>
                                                    <td>@(eLibraryProfile.HIndexCoreRincByYear.ContainsKey(year) ? eLibraryProfile.HIndexCoreRincByYear[year] : 0)</td>
                                                    <td>@(eLibraryProfile.PercentileCoreRincByYear.ContainsKey(year) ? eLibraryProfile.PercentileCoreRincByYear[year] : 0)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                            else
                            {
                                <div class="alert alert-light border">
                                    Годовые показатели не найдены.
                                </div>
                            }
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-light border">
                        Данные eLibrary пока не загружены.
                    </div>
                }
            </div>
        </div>
    </div>
</div>