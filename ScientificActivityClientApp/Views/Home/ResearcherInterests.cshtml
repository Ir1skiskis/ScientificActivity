@model List<ResearcherInterestViewModel>

@{
    ViewData["Title"] = "Научные интересы";
}

<h2 class="mb-4">Мои научные интересы</h2>

@if (TempData["Message"] != null)
{
    <div class="alert alert-success">@TempData["Message"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="mb-3">
    <a asp-action="CreateResearcherInterest" class="btn btn-primary">Добавить интерес</a>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">Интересы пока не добавлены.</div>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Ключевое слово</th>
                <th>Вес</th>
                <th style="width: 140px;">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var interest in Model)
            {
                <tr>
                    <td>@interest.Keyword</td>
                    <td>@interest.Weight</td>
                    <td>
                        <div class="d-flex gap-2">
                            <a asp-action="UpdateResearcherInterest" asp-route-id="@interest.Id" class="btn btn-warning btn-sm">Изменить</a>
                            <form method="post" asp-action="DeleteResearcherInterest">
                                <input type="hidden" name="id" value="@interest.Id" />
                                <button type="submit" class="btn btn-danger btn-sm">Удалить</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}