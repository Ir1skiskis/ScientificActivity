<script>
    function toggleRecommendationCard(button) {
        const card = button.closest('.recommendation-card');
        const text = button.querySelector('.recommendation-toggle-text');
        const icon = button.querySelector('.recommendation-toggle-icon');

        if (!card || !text || !icon) {
            return;
        }

        card.classList.toggle('expanded');

        if (card.classList.contains('expanded')) {
            text.textContent = 'Свернуть';
            icon.textContent = '⌃';
        } else {
            text.textContent = 'Показать полностью';
            icon.textContent = '⌄';
        }
    }
</script>