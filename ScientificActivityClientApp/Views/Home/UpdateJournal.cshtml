@{
    ViewData["Title"] = "Редактировать журнал";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card mt-4">
            <div class="card-header text-center"><h4>Редактировать журнал</h4></div>
            <div class="card-body">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form method="post" asp-action="UpdateJournal">
                    <input type="hidden" name="id" value="@ViewBag.JournalId" />

                    <div class="mb-3">
                        <label class="form-label">Название</label>
                        <input type="text" name="title" class="form-control" value="@ViewBag.TitleValue" required />
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">ISSN</label>
                            <input type="text" name="issn" class="form-control" value="@ViewBag.IssnValue" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">E-ISSN</label>
                            <input type="text" name="eIssn" class="form-control" value="@ViewBag.EIssnValue" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Издатель</label>
                        <input type="text" name="publisher" class="form-control" value="@ViewBag.PublisherValue" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Тематика</label>
                        <input type="text" name="subjectArea" class="form-control" value="@ViewBag.SubjectAreaValue" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Квартиль</label>
                        <select name="quartile" class="form-select">
                            <option value="0" selected="@(ViewBag.QuartileValue == 0)">Не указан</option>
                            <option value="1" selected="@(ViewBag.QuartileValue == 1)">Q1</option>
                            <option value="2" selected="@(ViewBag.QuartileValue == 2)">Q2</option>
                            <option value="3" selected="@(ViewBag.QuartileValue == 3)">Q3</option>
                            <option value="4" selected="@(ViewBag.QuartileValue == 4)">Q4</option>
                        </select>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="isVak" value="true" checked="@(ViewBag.IsVakValue == true)" />
                        <label class="form-check-label">Входит в ВАК</label>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" type="checkbox" name="isWhiteList" value="true" checked="@(ViewBag.IsWhiteListValue == true)" />
                        <label class="form-check-label">Входит в Белый список</label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Страна</label>
                        <input type="text" name="country" class="form-control" value="@ViewBag.CountryValue" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ссылка</label>
                        <input type="text" name="url" class="form-control" value="@ViewBag.UrlValue" />
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">Сохранить</button>
                        <a asp-action="Journals" class="btn btn-outline-secondary">Назад</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>