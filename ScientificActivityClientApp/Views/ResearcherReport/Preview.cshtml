@model ScientificActivityContracts.ViewModels.ResearcherReportViewModel

@{
    ViewData["Title"] = "Предварительный просмотр отчета";
    var profile = Model.Profile;
}

<style>
    .report-container {
        background: #ffffff;
        padding: 30px;
        border-radius: 8px;
        border: 1px solid #dee2e6;
    }

    .report-title {
        text-align: center;
        margin-bottom: 25px;
        font-weight: 600;
    }

    .report-section {
        margin-bottom: 30px;
    }

    .report-section h4 {
        margin-bottom: 15px;
        border-bottom: 1px solid #dee2e6;
        padding-bottom: 8px;
    }

    .report-table {
        width: 100%;
        border-collapse: collapse;
    }

    .report-table th,
    .report-table td {
        border: 1px solid #dee2e6;
        padding: 8px;
        vertical-align: top;
    }

    .report-table th {
        background: #f8f9fa;
        font-weight: 600;
    }

    .publication-item {
        margin-bottom: 15px;
        padding-bottom: 15px;
        border-bottom: 1px solid #e9ecef;
    }

    @@media print {
        body * {
            visibility: hidden !important;
        }

        #printArea,
        #printArea * {
            visibility: visible !important;
        }

        #printArea {
            position: absolute !important;
            left: 0 !important;
            top: 0 !important;
            width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
            border: none !important;
            background: #ffffff !important;
        }

        .no-print {
            display: none !important;
            visibility: hidden !important;
        }

        body {
            margin: 0 !important;
            padding: 0 !important;
            background: #ffffff !important;
            color: #000000 !important;
            font-size: 13px !important;
        }

        .container,
        .container-fluid,
        main,
        .report-container {
            width: 100% !important;
            max-width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        header,
        footer,
        nav,
        .navbar,
        .footer,
        .sidebar {
            display: none !important;
            visibility: hidden !important;
        }

        .report-section {
            page-break-inside: avoid;
            break-inside: avoid;
        }

        table {
            width: 100% !important;
            page-break-inside: auto;
            border-collapse: collapse !important;
        }

        tr {
            page-break-inside: avoid;
            page-break-after: auto;
        }

        h1, h2, h3, h4, h5 {
            page-break-after: avoid;
            break-after: avoid;
        }

        a {
            color: #000000 !important;
            text-decoration: none !important;
        }
    }
</style>

<div class="no-print mb-4 d-flex gap-2">
    <button type="button" class="btn btn-primary" onclick="window.print()">
        Печатать отчет
    </button>

    <form asp-action="DownloadPdf" method="post">
        @await Html.PartialAsync("_ReportSettingsHidden", Model.Settings)
        <button type="submit" class="btn btn-danger">
            Скачать PDF
        </button>
    </form>

    <form asp-action="DownloadDocx" method="post">
        @await Html.PartialAsync("_ReportSettingsHidden", Model.Settings)
        <button type="submit" class="btn btn-secondary">
            Скачать DOCX
        </button>
    </form>

    <a asp-action="Configure"
       asp-route-researcherId="@Model.Settings.ResearcherId"
       class="btn btn-outline-secondary">
        Изменить настройки
    </a>
</div>

<div id="printArea" class="report-container">

    <h2 class="report-title">@Model.Settings.ReportTitle</h2>

    <div class="report-section">
        <h4>Научная активность за период @Model.PeriodStatistic.StartYear–@Model.PeriodStatistic.EndYear</h4>

        <table class="report-table">
            <tbody>
                <tr>
                    <th>Количество публикаций за период</th>
                    <td>@Model.PeriodStatistic.PublicationsCount</td>
                </tr>
                <tr>
                    <th>Публикации, входящие в РИНЦ</th>
                    <td>@Model.PeriodStatistic.RincPublicationsCount</td>
                </tr>
                <tr>
                    <th>Публикации, входящие в ядро РИНЦ</th>
                    <td>@Model.PeriodStatistic.CoreRincPublicationsCount</td>
                </tr>
                <tr>
                    <th>Публикации в журналах ВАК</th>
                    <td>@Model.PeriodStatistic.VakPublicationsCount</td>
                </tr>
                <tr>
                    <th>Публикации в журналах Белого списка</th>
                    <td>@Model.PeriodStatistic.WhiteListPublicationsCount</td>
                </tr>
                <tr>
                    <th>Суммарное текущее число цитирований публикаций периода в РИНЦ</th>
                    <td>@Model.PeriodStatistic.CitationsRincCount</td>
                </tr>
            </tbody>
        </table>
    </div>

    <div class="report-section">
        <h4>Динамика публикационной активности по годам</h4>

        <table class="report-table">
            <thead>
                <tr>
                    <th>Год</th>
                    <th>Публикации</th>
                    <th>РИНЦ</th>
                    <th>Ядро РИНЦ</th>
                    <th>ВАК</th>
                    <th>Белый список</th>
                    <th>Цитирования РИНЦ</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.PeriodStatistic.YearStatistics)
                {
                    <tr>
                        <td>@item.Year</td>
                        <td>@item.PublicationsCount</td>
                        <td>@item.RincPublicationsCount</td>
                        <td>@item.CoreRincPublicationsCount</td>
                        <td>@item.VakPublicationsCount</td>
                        <td>@item.WhiteListPublicationsCount</td>
                        <td>@item.CitationsRincCount</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>


    @if (profile == null)
    {
        <div class="alert alert-warning">
            Данные профиля исследователя не найдены.
        </div>
    }
    else
    {
        @if (Model.Settings.IncludeCommonInfo)
        {
            <div class="report-section">
                <h4>1. Основные сведения об исследователе</h4>

                <table class="report-table">
                    <tbody>
                        <tr>
                            <th>ФИО</th>
                            <td>@profile.FullName</td>
                        </tr>
                        <tr>
                            <th>Организация</th>
                            <td>@profile.Organization</td>
                        </tr>
                        <tr>
                            <th>Кафедра</th>
                            <td>@profile.Department</td>
                        </tr>
                        <tr>
                            <th>AuthorID</th>
                            <td>@profile.AuthorId</td>
                        </tr>
                        <tr>
                            <th>SPIN-код</th>
                            <td>@profile.SpinCode</td>
                        </tr>
                        <tr>
                            <th>Основная рубрика ГРНТИ</th>
                            <td>@profile.MainRubricGrnti</td>
                        </tr>
                        <tr>
                            <th>Основная рубрика OECD</th>
                            <td>@profile.MainRubricOecd</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }

        @if (Model.Settings.IncludePublicationSummary)
        {
            <div class="report-section">
                <h4>2. Общие показатели публикационной активности</h4>

                <table class="report-table">
                    <thead>
                        <tr>
                            <th>Показатель</th>
                            <th>Значение</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Число публикаций в eLibrary</td>
                            <td>@profile.PublicationsCountElibrary</td>
                        </tr>
                        <tr>
                            <td>Число публикаций в РИНЦ</td>
                            <td>@profile.PublicationsCountRinc</td>
                        </tr>
                        <tr>
                            <td>Число публикаций в ядре РИНЦ</td>
                            <td>@profile.PublicationsCoreRincCount</td>
                        </tr>
                        <tr>
                            <td>Год первой публикации</td>
                            <td>@profile.FirstPublicationYear</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }

        @if (Model.Settings.IncludeCitationIndexes)
        {
            <div class="report-section">
                <h4>3. Показатели цитирования и индексы</h4>

                <table class="report-table">
                    <thead>
                        <tr>
                            <th>Показатель</th>
                            <th>Значение</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Цитирования в eLibrary</td>
                            <td>@profile.CitationsCountElibrary</td>
                        </tr>
                        <tr>
                            <td>Цитирования в РИНЦ</td>
                            <td>@profile.CitationsCountRinc</td>
                        </tr>
                        <tr>
                            <td>Цитирования в ядре РИНЦ</td>
                            <td>@profile.CitationsCoreRincCount</td>
                        </tr>
                        <tr>
                            <td>Индекс Хирша eLibrary</td>
                            <td>@profile.HIndexElibrary</td>
                        </tr>
                        <tr>
                            <td>Индекс Хирша РИНЦ</td>
                            <td>@profile.HIndexRinc</td>
                        </tr>
                        <tr>
                            <td>Индекс Хирша ядра РИНЦ</td>
                            <td>@profile.HIndexCoreRinc</td>
                        </tr>
                        <tr>
                            <td>Индекс Хирша без самоцитирований</td>
                            <td>@profile.HIndexWithoutSelfCitations</td>
                        </tr>
                        <tr>
                            <td>Среднее число цитирований на публикацию</td>
                            <td>@profile.AverageCitationsPerPublication</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }

        @if (Model.Settings.IncludeAdditionalMetrics)
        {
            <div class="report-section">
                <h4>4. Дополнительные наукометрические показатели</h4>

                <table class="report-table">
                    <thead>
                        <tr>
                            <th>Показатель</th>
                            <th>Значение</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Число публикаций, процитировавших автора</td>
                            <td>@profile.PublicationsCitingAuthorCount</td>
                        </tr>
                        <tr>
                            <td>Число цитирований самой цитируемой публикации</td>
                            <td>@profile.MostCitedPublicationCitationsCount</td>
                        </tr>
                        <tr>
                            <td>Число процитированных публикаций</td>
                            <td>@profile.CitedPublicationsCount</td>
                        </tr>
                        <tr>
                            <td>Самоцитирования</td>
                            <td>@profile.SelfCitationsCount</td>
                        </tr>
                        <tr>
                            <td>Цитирования соавторов</td>
                            <td>@profile.CoauthorCitationsCount</td>
                        </tr>
                        <tr>
                            <td>Количество соавторов</td>
                            <td>@profile.CoauthorsCount</td>
                        </tr>
                        <tr>
                            <td>Перцентиль ядра РИНЦ</td>
                            <td>@profile.PercentileCoreRinc</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }

        @if (Model.Settings.IncludeJournalMetrics)
        {
            <div class="report-section">
                <h4>5. Показатели журнальной активности</h4>

                <table class="report-table">
                    <thead>
                        <tr>
                            <th>Показатель</th>
                            <th>Значение</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Публикации в зарубежных журналах</td>
                            <td>@profile.ForeignArticlesCount</td>
                        </tr>
                        <tr>
                            <td>Публикации в российских журналах</td>
                            <td>@profile.RussianArticlesCount</td>
                        </tr>
                        <tr>
                            <td>Публикации в журналах ВАК</td>
                            <td>@profile.VakArticlesCount</td>
                        </tr>
                        <tr>
                            <td>Публикации в журналах с импакт-фактором</td>
                            <td>@profile.ImpactFactorArticlesCount</td>
                        </tr>
                        <tr>
                            <td>Цитирования из российских журналов</td>
                            <td>@profile.RussianJournalCitationsCount</td>
                        </tr>
                        <tr>
                            <td>Цитирования из журналов ВАК</td>
                            <td>@profile.VakJournalCitationsCount</td>
                        </tr>
                        <tr>
                            <td>Цитирования из журналов с импакт-фактором</td>
                            <td>@profile.ImpactFactorJournalCitationsCount</td>
                        </tr>
                        <tr>
                            <td>Средневзвешенный импакт-фактор журналов, в которых опубликованы статьи</td>
                            <td>@profile.AverageWeightedImpactFactorPublished</td>
                        </tr>
                        <tr>
                            <td>Средневзвешенный импакт-фактор журналов, в которых процитированы статьи</td>
                            <td>@profile.AverageWeightedImpactFactorCited</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }

        @if (Model.Settings.IncludeLastFiveYearsMetrics)
        {
            <div class="report-section">
                <h4>6. Показатели за последние 5 лет</h4>

                <table class="report-table">
                    <thead>
                        <tr>
                            <th>Показатель</th>
                            <th>Значение</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Публикации РИНЦ за последние 5 лет</td>
                            <td>@profile.PublicationsRincLast5YearsCount</td>
                        </tr>
                        <tr>
                            <td>Публикации ядра РИНЦ за последние 5 лет</td>
                            <td>@profile.PublicationsCoreRincLast5YearsCount</td>
                        </tr>
                        <tr>
                            <td>Цитирования РИНЦ за последние 5 лет</td>
                            <td>@profile.CitationsRincLast5YearsCount</td>
                        </tr>
                        <tr>
                            <td>Цитирования ядра РИНЦ за последние 5 лет</td>
                            <td>@profile.CitationsCoreRincLast5YearsCount</td>
                        </tr>
                        <tr>
                            <td>Все цитирования за последние 5 лет</td>
                            <td>@profile.CitationsAllLast5YearsCount</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }

        @if (Model.Settings.IncludeYearDynamics)
        {
            <div class="report-section">
                <h4>7. Динамика показателей по годам</h4>

                <table class="report-table">
                    <thead>
                        <tr>
                            <th>Год</th>
                            <th>Публикации РИНЦ</th>
                            <th>Публикации ядра РИНЦ</th>
                            <th>Цитирования РИНЦ</th>
                            <th>Цитирования ядра РИНЦ</th>
                            <th>h-index РИНЦ</th>
                            <th>h-index ядра РИНЦ</th>
                            <th>Перцентиль ядра РИНЦ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var year in Model.PublicationsRincByYear.Keys.OrderBy(x => x))
                        {
                            <tr>
                                <td>@year</td>
                                <td>@GetValue(Model.PublicationsRincByYear, year)</td>
                                <td>@GetValue(Model.PublicationsCoreRincByYear, year)</td>
                                <td>@GetValue(Model.CitationsRincByYear, year)</td>
                                <td>@GetValue(Model.CitationsCoreRincByYear, year)</td>
                                <td>@GetValue(Model.HIndexRincByYear, year)</td>
                                <td>@GetValue(Model.HIndexCoreRincByYear, year)</td>
                                <td>@GetValue(Model.PercentileCoreRincByYear, year)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <div class="report-section">
                <h4>8. Пятилетние показатели по годам окончания периода</h4>

                <table class="report-table">
                    <thead>
                        <tr>
                            <th>Год окончания периода</th>
                            <th>Публикации РИНЦ за 5 лет</th>
                            <th>Публикации ядра РИНЦ за 5 лет</th>
                            <th>Цитирования РИНЦ за 5 лет</th>
                            <th>Цитирования ядра РИНЦ за 5 лет</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var year in Model.PublicationsRinc5YearsByEndYear.Keys.OrderBy(x => x))
                        {
                            <tr>
                                <td>@year</td>
                                <td>@GetValue(Model.PublicationsRinc5YearsByEndYear, year)</td>
                                <td>@GetValue(Model.PublicationsCoreRinc5YearsByEndYear, year)</td>
                                <td>@GetValue(Model.CitationsRinc5YearsByEndYear, year)</td>
                                <td>@GetValue(Model.CitationsCoreRinc5YearsByEndYear, year)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        @if (Model.Settings.IncludePublications)
        {
            <div class="report-section">
                <h4>9. Список публикаций за выбранный период</h4>

                @if (Model.PeriodPublications == null || !Model.PeriodPublications.Any())
                {
                    <p>Публикации за выбранный период не найдены.</p>
                }
                else
                {
                    <p>
                        Всего публикаций за выбранный период:
                        <strong>@Model.PeriodPublications.Count</strong>
                    </p>

                    @foreach (var publication in Model.PeriodPublications)
                    {
                        <div class="publication-item">
                            <strong>@publication.Year. @publication.Title</strong>

                            <div>
                                Авторы: @publication.Authors
                            </div>

                            @if (!string.IsNullOrWhiteSpace(publication.JournalTitle))
                            {
                                <div>
                                    Журнал: @publication.JournalTitle
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(publication.ConferenceTitle))
                            {
                                <div>
                                    Конференция: @publication.ConferenceTitle
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(publication.Doi))
                            {
                                <div>
                                    DOI: @publication.Doi
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(publication.Url))
                            {
                                <div>
                                    Ссылка: @publication.Url
                                </div>
                            }

                            <div>
                                Цитирований РИНЦ: @(publication.CitationsRincCount ?? 0)
                            </div>

                            <div>
                                Признаки:
                                @if (publication.IsInRinc)
                                {
                                    <span>РИНЦ; </span>
                                }
                                @if (publication.IsInCoreRinc)
                                {
                                    <span>ядро РИНЦ; </span>
                                }
                                @if (publication.IsVak)
                                {
                                    <span>ВАК; </span>
                                }
                                @if (publication.IsWhiteListLevel1)
                                {
                                    <span>Белый список 1; </span>
                                }
                                @if (publication.IsWhiteListLevel2)
                                {
                                    <span>Белый список 2; </span>
                                }
                                @if (publication.IsWhiteListLevel3)
                                {
                                    <span>Белый список 3; </span>
                                }
                                @if (publication.IsWhiteListLevel4)
                                {
                                    <span>Белый список 4; </span>
                                }
                            </div>
                        </div>
                    }
                }
            </div>
        }
    }

    <div class="mt-4 text-muted">
        Дата формирования отчета: @Model.GeneratedAt.ToString("dd.MM.yyyy HH:mm")
    </div>
</div>

@functions {
    private int GetValue(Dictionary<int, int> dictionary, int year)
    {
        if (dictionary == null)
        {
            return 0;
        }

        return dictionary.TryGetValue(year, out var value) ? value : 0;
    }
}